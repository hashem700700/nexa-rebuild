{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx src/server.ts",
    "build": "vite build && esbuild src/server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "preview": "vite preview",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit",
    "prepare": "husky || true"
  },
  "lint-staged": {
    "src/domains/**/*.ts": [
      "node scripts/check-domain-boundaries.js"
    ]
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "body-parser": "^2.2.2",
    "dotenv": "^17.2.3",
    "express": "^4.22.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "pg": "^8.21.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "ts-node": "^10.9.2",
    "vite": "^6.2.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@prisma/client": "^7.8.0",
    "@types/express": "^4.17.25",
    "@types/node": "^22.14.0",
    "@types/pg": "^8.20.0",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.12",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.6",
    "prisma": "^7.8.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.22.3",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
