generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model system_tenants {
  tenant_id    String @id @db.Uuid
  company_name String @db.VarChar(255)
  status       String @db.VarChar(50)
}

model chart_of_accounts {
  account_id   String @id @db.VarChar(255)
  tenant_id    String @db.Uuid
  account_name String @db.VarChar(255)
  account_type String @db.VarChar(50)
}

model warehouses {
  warehouse_id   String @id @db.VarChar(255)
  tenant_id      String @db.Uuid
  warehouse_name String @db.VarChar(255)
}

model item_master {
  item_id   String @id @db.VarChar(255)
  tenant_id String @db.Uuid
  item_name String @db.VarChar(255)
}

model stock_movements {
  movement_id        Int     @id @default(autoincrement())
  tenant_id          String  @db.Uuid
  warehouse_id       String  @db.VarChar(255)
  item_id            String  @db.VarChar(255)
  quantity           Decimal @db.Decimal
  movement_type      String  @db.VarChar(50)
  reference_document String? @db.VarChar(255)
  correlation_id     String  @db.Uuid
  status             String  @db.VarChar(50)
}

model journal_entries {
  journal_id     String   @id @db.VarChar(255)
  tenant_id      String   @db.Uuid
  correlation_id String   @db.Uuid
  journal_date   DateTime @db.Date
  description    String?  @db.Text
  status         String   @db.VarChar(50)
  valid_from     DateTime @default(now()) @db.Timestamptz
  valid_to       DateTime @default(dbgenerated("'9999-12-31 23:59:59+00'::timestamp with time zone")) @db.Timestamptz
}

model journal_lines {
  line_id              Int     @id @default(autoincrement())
  tenant_id            String  @db.Uuid
  journal_id           String  @db.VarChar(255)
  account_id           String  @db.VarChar(255)
  debit_amount         Decimal @db.Decimal
  credit_amount        Decimal @db.Decimal
  transaction_currency String  @db.VarChar(10)
  exchange_rate        Decimal @db.Decimal
  base_debit_amount    Decimal @db.Decimal
  base_credit_amount   Decimal @db.Decimal
}

model outbox_events {
  event_id        Int    @id @default(autoincrement())
  tenant_id       String @db.Uuid
  correlation_id  String @db.Uuid
  idempotency_key String @unique @db.VarChar(255)
  aggregate_type  String @db.VarChar(255)
  aggregate_id    String @db.VarChar(255)
  event_type      String @db.VarChar(255)
  payload         Json   @db.JsonB
  status          String @db.VarChar(50)
}

model projection_inventory_stock {
  tenant_id        String  @db.Uuid
  warehouse_id     String  @db.VarChar(255)
  item_id          String  @db.VarChar(255)
  quantity_on_hand Decimal @db.Decimal

  @@unique([tenant_id, warehouse_id, item_id])
}

// ==========================================
// AUTHORIZATION KERNEL (RBAC/ABAC/SoD)
// ==========================================

model auth_roles {
  role_id     String @id @db.VarChar(255)
  tenant_id   String @db.Uuid
  role_name   String @db.VarChar(255)
  description String? @db.Text
  
  @@unique([tenant_id, role_name])
}

model auth_role_permissions {
  tenant_id   String @db.Uuid
  role_id     String @db.VarChar(255)
  resource    String @db.VarChar(255)
  action      String @db.VarChar(50)
  
  @@id([tenant_id, role_id, resource, action])
}

model auth_user_roles {
  tenant_id   String @db.Uuid
  user_id     String @db.VarChar(255)
  role_id     String @db.VarChar(255)

  @@id([tenant_id, user_id, role_id])
}

model auth_sod_conflicts {
  tenant_id       String @db.Uuid
  conflict_id     String @id @db.VarChar(255)
  role_a          String @db.VarChar(255)
  role_b          String @db.VarChar(255)
  description     String? @db.Text
}

model auth_audit_log {
  audit_id      String @id @db.Uuid // UUID instead of autoincrement for security tracing
  tenant_id     String @db.Uuid
  user_id       String @db.VarChar(255)
  resource      String @db.VarChar(255)
  action        String @db.VarChar(50)
  decision      String @db.VarChar(50) // e.g. "PERMIT", "DENY"
  decision_hash String @db.VarChar(255)
  timestamp     DateTime @default(now()) @db.Timestamptz
}
